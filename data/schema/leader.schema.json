{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://frontierwomenindex.org/schema/leader.schema.json",
  "title": "Frontier Women Index Leader Entry",
  "description": "Schema for a single leader entry in the Frontier Women Index.",
  "type": "object",
  "required": [
    "id",
    "name",
    "origin",
    "current_roles",
    "domains",
    "tier",
    "tier_justification",
    "summary",
    "links",
    "verification"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "URL-safe slug used as the filename and stable identifier. Must be unique across the dataset."
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "description": "Full name as the leader is typically credited in published work."
    },
    "honorific": {
      "type": "string",
      "enum": ["Dr.", "Prof.", "", null],
      "description": "Optional prefix. Omit unless the leader consistently uses it in their own bios."
    },
    "also_known_as": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Alternative names, former names, or common shortenings."
    },
    "origin": {
      "type": "object",
      "required": ["country_of_birth"],
      "additionalProperties": false,
      "properties": {
        "country_of_birth": {
          "type": "string",
          "description": "ISO 3166 country name (not code), e.g., 'India', 'United States'."
        },
        "country_of_work": {
          "type": "string",
          "description": "Country where the leader currently works. Omit if same as country_of_birth."
        },
        "migration_path": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ordered list of countries in the leader's career path, e.g., ['India', 'United States']."
        },
        "india_connection": {
          "type": "boolean",
          "description": "True if leader was born, raised, or educated in India, or is of Indian origin."
        }
      }
    },
    "current_roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "institution"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "institution": {
            "type": "string",
            "description": "Slug matching an entry in data/institutions/ where possible."
          },
          "start": {
            "type": "integer",
            "description": "Year the role started. Optional."
          },
          "source": {
            "type": "string",
            "format": "uri",
            "description": "URL verifying the role. Required for verified entries."
          }
        }
      }
    },
    "previous_roles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "institution"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "institution": { "type": "string" },
          "start": { "type": "integer" },
          "end": { "type": "integer" },
          "source": { "type": "string", "format": "uri" }
        }
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["degree", "institution"],
        "additionalProperties": false,
        "properties": {
          "degree": {
            "type": "string",
            "enum": ["BSc", "BA", "BTech", "BEng", "BE", "MSc", "MA", "MTech", "MEng", "MBA", "MD", "PhD", "MS", "MPhil", "Other"]
          },
          "institution": { "type": "string" },
          "year": { "type": "integer" },
          "advisor": { "type": "string" },
          "source": { "type": "string", "format": "uri" }
        }
      }
    },
    "domains": {
      "type": "object",
      "required": ["primary"],
      "additionalProperties": false,
      "properties": {
        "primary": {
          "type": "string",
          "enum": [
            "AI",
            "BioIntelligence",
            "Robotics",
            "Quantum Computing",
            "Space",
            "Aerospace",
            "Neuroscience",
            "Enterprise Tech",
            "Semiconductors",
            "STEM"
          ]
        },
        "secondary": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Freeform sub-domain tags, e.g., 'CRISPR', 'Transformers', 'Autonomous Driving'."
        }
      }
    },
    "tier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Tier assignment. See METHODOLOGY.md for criteria."
    },
    "tier_justification": {
      "type": "string",
      "minLength": 30,
      "description": "Specific credentials placing the leader in their tier. Must cite the specific criteria from METHODOLOGY.md that are met."
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "citations_scholar": { "type": "integer", "minimum": 0 },
        "citations_snapshot_date": { "type": "string", "format": "date" },
        "citations_source": { "type": "string", "format": "uri" },
        "h_index": { "type": "integer", "minimum": 0 },
        "h_index_snapshot_date": { "type": "string", "format": "date" }
      }
    },
    "awards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "year"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "year": { "type": "integer" },
          "organization": { "type": "string" },
          "source": { "type": "string", "format": "uri" }
        }
      }
    },
    "ventures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["company", "research_institute", "nonprofit", "lab", "other"]
          },
          "role": { "type": "string" },
          "founded": { "type": "integer" },
          "capital_raised_usd": { "type": "number" },
          "latest_valuation_usd": { "type": "number" },
          "valuation_date": { "type": "string", "format": "date" },
          "source": { "type": "string", "format": "uri" }
        }
      }
    },
    "key_works": {
      "type": "array",
      "description": "Up to 5 signature publications, products, or contributions.",
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["title"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "year": { "type": "integer" },
          "venue": { "type": "string" },
          "citation_count": { "type": "integer" },
          "url": { "type": "string", "format": "uri" }
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 80,
      "maxLength": 800,
      "description": "2-4 sentence summary of the leader's contribution. Narrative but factually grounded."
    },
    "links": {
      "type": "object",
      "required": ["primary"],
      "additionalProperties": false,
      "properties": {
        "primary": {
          "type": "string",
          "format": "uri",
          "description": "The single best public source for learning more about this leader."
        },
        "wikipedia": { "type": "string", "format": "uri" },
        "scholar": { "type": "string", "format": "uri" },
        "orcid": { "type": "string", "pattern": "^\\d{4}-\\d{4}-\\d{4}-\\d{3}[0-9X]$" },
        "website": { "type": "string", "format": "uri" },
        "github": { "type": "string", "format": "uri" }
      }
    },
    "relationships": {
      "type": "array",
      "description": "Connections to other leaders in the Index. Used to build the Research Graph.",
      "items": {
        "type": "object",
        "required": ["type", "target"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["advisor", "advisee", "co-author", "co-founder", "successor", "predecessor", "collaborator"]
          },
          "target": {
            "type": "string",
            "description": "The id of the other leader."
          },
          "context": { "type": "string" },
          "source": { "type": "string", "format": "uri" }
        }
      }
    },
    "verification": {
      "type": "object",
      "required": ["status", "last_reviewed"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["verified", "partially_verified", "unverified"]
        },
        "last_reviewed": { "type": "string", "format": "date" },
        "reviewer": { "type": "string" },
        "second_reviewer": {
          "type": "string",
          "description": "Required for status: verified."
        },
        "notes": { "type": "string" }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Freeform tags for filtering on the site."
    }
  }
}
